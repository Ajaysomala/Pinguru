# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=pinguru

# ── Meta / Instagram ───────────────────────────────────────────────────────────
META_APP_ID=111111111111111
META_APP_SECRET=your_meta_app_secret_here
META_WEBHOOK_VERIFY_TOKEN=pinguru_webhook_secret_2024
INSTAGRAM_GRAPH_API_VERSION=v19.0

# ── JWT & Encryption ────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_random_64_char_string_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
ENCRYPTION_KEY=GENERATE_WITH_FERNET_GENERATE_KEY
ADMIN_API_KEY=your_admin_api_secret_key_change_this
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# ── Google OAuth ───────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
DEFAULT_OAUTH_PASSWORD=TempOAuth2024!

# ── Stripe (add later) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FREE=price_FREE
STRIPE_PRICE_STARTER_199=price_STARTER_199
STRIPE_PRICE_PRO_399=price_PRO_399

# ── App ────────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DISABLE_WEBHOOK_SIGNATURE=false