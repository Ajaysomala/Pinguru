# ── MongoDB ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=pinguru

# ── Meta / Instagram ───────────────────────────────────────────────────────────
META_APP_ID=111111111111111
META_APP_SECRET=your_meta_app_secret_here
META_WEBHOOK_VERIFY_TOKEN=pinguru_webhook_secret_2024

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_a_random_64_char_string_here
ENCRYPTION_KEY=GENERATE_WITH_FERNET_GENERATE_KEY
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# ── Stripe (add later) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_FREE=price_FREE
STRIPE_PRICE_STARTER_199=price_STARTER_199
STRIPE_PRICE_PRO_399=price_PRO_399

# ── App ────────────────────────────────────────────────────────────────────────
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development

# -- Admin credentials for initial setup (change before production) ---

ENCRYPTION_KEY=GENERATE_WITH_FERNET_GENERATE_KEY
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash
STRIPE_WEBHOOK_SECRET=whsec_test_xxx